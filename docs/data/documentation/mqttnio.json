-services"},{"type":"text","text":" (required for iOS)."}]}]}]},{"level":2,"anchor":"Usage","type":"heading","text":"Usage"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Create a client and connect to the MQTT broker."}]},{"type":"codeListing","code":["let client = MQTTClient(","    host: \"mqtt.eclipse.org\",","    port: 1883,","    identifier: \"My Client\",","    eventLoopGroupProvider: .createNew",")","do {","    try await client.connect()","    print(\"Succesfully connected\")","} catch {","    print(\"Error while connecting \\(error)\")","}"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Subscribe to a topic and add a publish listener to report publish messages sent from the server\/broker."}]},{"type":"codeListing","code":["let subscription = MQTTSubscribeInfo(topicFilter: \"my-topics\", qos: .atLeastOnce)","_ = try await client.subscribe(to: [subscription])","let listener = client.createPublishListener()","for await result in listener {","    switch result {","    case .success(let publish):","        if publish.topicName == \"my-topics\" {","            var buffer = publish.payload","            let string = buffer.readString(length: buffer.readableBytes)","            print(string)","        }","    case .failure(let error):","        print(\"Error while receiving PUBLISH event\")","    }","}"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Publish to a topic."}]},{"type":"codeListing","code":["try await client.publish(","    to: \"my-topics\",","    payload: ByteBuffer(string: \"This is the Test payload\"),","    qos: .atLeastOnce",")"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"MQTTClient supports both Swift concurrency and SwiftNIO "},{"code":"EventLoopFuture","type":"codeVoice"},{"type":"text","text":". The above examples use Swift concurrency but there are equivalent versions of these functions that return "},{"code":"EventLoopFuture","type":"codeVoice"},{"type":"text","text":"s. You can find out more about Swift NIO and "},{"code":"EventLoopFuture","type":"codeVoice"},{"type":"text","text":" "},{"type":"reference","identifier":"https:\/\/swiftpackageindex.com\/apple\/swift-nio\/main\/documentation\/niocore\/eventloopfuture","isActive":true},{"type":"text","text":"."}]}]}],"schemaVersion":{"minor":3,"patch":0,"major":0},"variants":[{"paths":["\/documentation\/mqttnio"],"traits":[{"interfaceLanguage":"swift"}]}],"metadata":{"role":"collection","symbolKind":"module","modules":[{"name":"MQTTNIO"}],"roleHeading":"Framework","title":"MQTTNIO","externalID":"MQTTNIO"},"hierarchy":{"paths":[[]]},"references":{"doc://org.swift-server-community.mqtt-nio/documentation/MQTTNIO/MQTTPublishInfo":{"kind":"symbol","title":"MQTTPublishInfo","role":"symbol","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"MQTTPublishInfo"}],"abstract":[{"type":"text","text":"MQTT PUBLISH packet parameters."}],"url":"\/documentation\/mqttnio\/mqttpublishinfo","navigatorTitle":[{"kind":"identifier","text":"MQTTPublishInfo"}],"identifier":"doc:\/\/org.swift-server-community.mqtt-nio\/documentation\/MQTTNIO\/MQTTPublishInfo","type":"topic"},"doc://org.swift-server-community.mqtt-nio/documentation/MQTTNIO/TSCertificateVerification":{"title":"TSCertificateVerification","navigatorTitle":[{"kind":"identifier","text":"TSCertificateVerification"}],"abstract":[{"type":"text","text":"Certificate verification modes."}],"type":"topic","url":"\/documentation\/mqttnio\/tscertificateverification","identifier":"doc:\/\/org.swift-server-community.mqtt-nio\/documentation\/MQTTNIO\/TSCertificateVerification","kind":"symbol","role":"symbol","fragments":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"TSCertificateVerification"}]},"doc://org.swift-server-community.mqtt-nio/documentation/MQTTNIO/mqttnio-connections":{"title":"Connections","kind":"article","identifi